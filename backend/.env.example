# Telegram Bot Token (von @BotFather auf Telegram)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Server Port
PORT=3001

# Frontend URL (für CORS — lokale Electron-Dev-URL)
FRONTEND_URL=https://mindvault.ch

# Erlaubte CORS-Origins (kommagetrennt, für Cloud-Frontend)
ALLOWED_ORIGINS=https://mindvault.ch,https://mindvault-49z.pages.dev

# App URL für Telegram-Links im Share-Poller (Cloudflare Pages custom domain)
APP_URL=https://mindvault.ch

# ngrok Subdomain (optional, für feste URL)
# NGROK_SUBDOMAIN=mindvault
