# Telegram Bot Token (von @BotFather auf Telegram)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Server Port
PORT=3001

# Frontend URL (für CORS — lokale Electron-Dev-URL)
FRONTEND_URL=http://localhost:3000

# Deployed web frontend URL (Cloudflare Pages or Vercel)
# Used by supabase-poller as APP_URL.
# After migrating to Cloudflare, set this to your Cloudflare Pages URL, e.g.:
#   APP_URL=https://mindvault.pages.dev
# or with custom domain:
#   APP_URL=https://mindvault.app
APP_URL=https://mind-vault-chi.vercel.app

# ngrok Subdomain (optional, für feste URL)
# NGROK_SUBDOMAIN=mindvault
