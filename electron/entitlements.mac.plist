<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Allow JIT compilation (required for Node.js / V8 in Electron) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (required for Electron renderer) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow dyld environment variables (required for native modules) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Disable library validation (required for Electron — frameworks were
         originally signed by GitHub/Electron team; re-signing with Developer ID
         can cause Team ID mismatches that crash dyld at launch without this) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access (backend HTTP server + internet for activation/updates) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access: read user-selected files (for drag & drop imports) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Downloads folder access (for saving clips/GIFs) -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
  </dict>
</plist>
